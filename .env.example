# =============================================================================
# DigiSwarm — client env
#
# Copy this file to `.env` for local overrides. Vite reads .env automatically.
# =============================================================================

# --- Local development ----------------------------------------------------
# Leave VITE_API_BASE_URL UNSET locally. The Vite dev server proxies /api/*
# to the backend (see vite.config.js), so there are no CORS/port issues and
# axios just calls "/api/v1/...".
#
# Optionally override the proxy target if your backend is on a different port:
# VITE_API_TARGET=http://localhost:5000

# --- Production / staging -------------------------------------------------
# When the SPA is hosted on a different domain than the API, set this to the
# full backend URL including the /api/v1 prefix. Configure it in the hosting
# dashboard (Vercel → Project → Settings → Environment Variables) — do NOT
# commit a real value here.
# VITE_API_BASE_URL=https://digis-warm-server.vercel.app/api/v1

# --- Branding -------------------------------------------------------------
VITE_SITE_NAME=DigiSwarm
